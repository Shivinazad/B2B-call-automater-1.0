# API Keys (Free Tier / Sandbox)

# Hugging Face Inference API (Free)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Voice AI (Free Trial Credits)
# Use one of: Vapi.ai, Retell AI, or Twilio
VAPI_API_KEY=your_vapi_api_key_here
RETELL_API_KEY=your_retell_api_key_here
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here

# Scraping (Free Tier)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# Or use SCRAPINGBEE_API_KEY if preferred

# Currency Conversion (Free)
# Using exchangerate-api.com (free tier: 1500 requests/month)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# API Setu (Sandbox for PAN/GST verification)
API_SETU_CLIENT_ID=your_api_setu_client_id_here
API_SETU_CLIENT_SECRET=your_api_setu_client_secret_here

# Optional: SendGrid for email (Free tier: 100 emails/day)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
